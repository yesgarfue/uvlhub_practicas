# Configuración de Flask
FLASK_APP_NAME="UVLHUB.IO(production)"
FLASK_ENV=production
DOMAIN=your-production-domain.com

# Configuración de MariaDB
MARIADB_HOSTNAME=db
MARIADB_PORT=3306
MARIADB_DATABASE=uvlhubdb
MARIADB_TEST_DATABASE=uvlhubdb_test
MARIADB_USER=uvlhubdb_user
MARIADB_PASSWORD=uvlhubdb_root_password
MARIADB_ROOT_PASSWORD=uvlhubdb_root_password

# Directorio de trabajo en el contenedor
WORKING_DIR=/app

# Configuración de Render (para las APIs de despliegue)
RENDER_SERVICE_ID=
RENDER_API_KEY=